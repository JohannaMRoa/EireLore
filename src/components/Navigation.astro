---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/myths", label: "Myths" },
  { href: "/glossary", label: "Glossary" },
  { href: "/team", label: "Team" },
];

const currentPath = Astro.url.pathname;
---

<header
  id="main-nav"
  class="fixed left-0 top-4 z-50 w-full px-4 transition-transform duration-500 md:top-6 md:px-10"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between rounded-full border border-gold/20 bg-dark/65 px-4 py-2 shadow-[0_18px_60px_-24px_rgba(0,0,0,0.75)] backdrop-blur-2xl md:px-6">
    <!-- Logo -->
    <a href="/" class="flex items-center no-underline">
      <img
        src="/logo-2.svg"
        alt="Éire Lore"
        class="h-11 w-auto object-contain md:h-12"
      />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-2 list-none md:flex">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href;
        return (
          <li>
            <a
              href={link.href}
              class={`relative inline-flex rounded-full px-5 py-2 text-xs font-semibold uppercase tracking-[0.16em] no-underline transition-all duration-300 ${
                isActive
                  ? "bg-gold text-dark shadow-[0_0_25px_rgba(220,180,90,0.35)]"
                  : "text-sand/75 hover:bg-sand/10 hover:text-gold"
              }`}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- Right -->
    <div class="flex items-center gap-3">
      <!-- Search -->
      <div class="relative flex items-center">
        <input
          id="search-input"
          type="text"
          placeholder="Search myths..."
          class="absolute right-14 top-1/2 hidden h-11 w-52 -translate-y-1/2 rounded-full border border-gold/25 bg-dark/95 px-5 text-sm text-sand placeholder:text-sand/45 outline-none shadow-[0_12px_35px_-18px_rgba(0,0,0,0.8)] backdrop-blur-xl transition focus:border-gold"
        />

        <button
          id="search-btn"
          aria-label="Search"
          type="button"
          class="flex h-11 w-11 items-center justify-center rounded-full border border-gold/25 bg-sand/5 text-sand transition hover:border-gold hover:bg-gold hover:text-dark"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            class="h-5 w-5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 21l-4.35-4.35m1.6-5.15a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z"
            />
          </svg>
        </button>
      </div>

      <!-- Mobile menu -->
      <button
        id="menu-btn"
        aria-label="Open menu"
        type="button"
        class="flex h-11 w-11 items-center justify-center rounded-full border border-gold/25 bg-sand/5 text-sand transition hover:border-gold hover:bg-gold hover:text-dark md:hidden"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
          class="h-6 w-6"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
          />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="mx-auto mt-3 hidden max-w-md rounded-[2rem] border border-gold/20 bg-dark/90 p-3 shadow-[0_18px_60px_-24px_rgba(0,0,0,0.85)] backdrop-blur-2xl md:hidden"
  >
    <ul class="flex flex-col gap-2 list-none">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href;
        return (
          <li>
            <a
              href={link.href}
              class={`block rounded-full px-5 py-3 text-sm font-semibold uppercase tracking-[0.12em] no-underline transition ${
                isActive
                  ? "bg-gold text-dark"
                  : "text-sand hover:bg-sand/10 hover:text-gold"
              }`}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</header>

<script>
  const searchBtn = document.getElementById("search-btn");
  const searchInput = document.getElementById("search-input");
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  if (searchBtn && searchInput) {
    searchBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      searchInput.classList.toggle("hidden");
      if (!searchInput.classList.contains("hidden")) searchInput.focus();
    });

    searchInput.addEventListener("click", (e) => e.stopPropagation());
  }

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      mobileMenu.classList.toggle("hidden");
    });

    mobileMenu.addEventListener("click", (e) => e.stopPropagation());
  }

  document.addEventListener("click", () => {
    if (searchInput && !searchInput.classList.contains("hidden")) {
      searchInput.classList.add("hidden");
    }
    if (mobileMenu && !mobileMenu.classList.contains("hidden")) {
      mobileMenu.classList.add("hidden");
    }
  });
</script>

<script>
  const nav = document.getElementById("main-nav");

  let lastScrollY = window.scrollY;
  let isHoveringNav = false;

  if (nav) {
    nav.addEventListener("mouseenter", () => {
      isHoveringNav = true;
      nav.classList.remove("-translate-y-full");
    });

    nav.addEventListener("mouseleave", () => {
      isHoveringNav = false;
    });

    window.addEventListener("scroll", () => {
      const currentScrollY = window.scrollY;

      if (isHoveringNav) return;

      if (currentScrollY > lastScrollY && currentScrollY > 80) {
        nav.classList.add("-translate-y-full");
      } else {
        nav.classList.remove("-translate-y-full");
      }

      lastScrollY = currentScrollY;
    });

    document.addEventListener("mousemove", (e) => {
      if (e.clientY < 90) {
        nav.classList.remove("-translate-y-full");
      }
    });
  }
</script>