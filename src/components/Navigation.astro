---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/myths", label: "Myths" },
  { href: "/glossary", label: "Glossary" },
  { href: "/team", label: "Team" },
];

const currentPath = Astro.url.pathname;
---

<header
  id="main-nav"
  class="fixed left-0 top-4 z-50 w-full px-4 transition-all duration-300 md:top-6 md:px-10"
>
  <nav
    id="nav-inner"
    class="mx-auto flex max-w-7xl items-center justify-between rounded-full border border-gold/20 bg-dark/65 px-4 py-2 shadow-[0_18px_60px_-24px_rgba(0,0,0,0.75)] backdrop-blur-2xl transition-all duration-300 md:px-6"
  >
    <a href="/" class="flex items-center no-underline">
      <img
        src="/logo-2.svg"
        alt="Éire Lore"
        class="h-11 w-auto object-contain transition-all duration-300 md:h-12"
        id="nav-logo"
      />
    </a>

    <ul class="hidden items-center gap-2 list-none md:flex">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href;
        return (
          <li>
            <a
              href={link.href}
              class={`relative inline-flex rounded-full px-5 py-2 text-xs font-semibold uppercase tracking-[0.16em] no-underline transition-all duration-300 ${
                isActive
                  ? "bg-gold text-dark shadow-[0_0_25px_rgba(220,180,90,0.35)]"
                  : "text-sand/75 hover:bg-sand/10 hover:text-gold"
              }`}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>

    <div class="flex items-center gap-3">
      <div class="relative flex items-center">
        <input
          id="search-input"
          type="text"
          placeholder="Search myths..."
          class="absolute right-14 top-1/2 hidden h-11 w-52 -translate-y-1/2 rounded-full border border-gold/25 bg-dark/95 px-5 text-sm text-sand placeholder:text-sand/45 outline-none backdrop-blur-xl transition"
        />

        <button
          id="search-btn"
          type="button"
          class="flex h-11 w-11 items-center justify-center rounded-full border border-gold/25 bg-sand/5 text-sand transition"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.6-5.15a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z"/>
          </svg>
        </button>
      </div>

      <button
        id="menu-btn"
        type="button"
        class="flex h-11 w-11 items-center justify-center rounded-full border border-gold/25 bg-sand/5 text-sand transition md:hidden"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" class="h-6 w-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
        </svg>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="mx-auto mt-3 hidden max-w-md rounded-[2rem] border border-gold/20 bg-dark/90 p-3 backdrop-blur-2xl md:hidden"
  >
    <ul class="flex flex-col gap-2 list-none">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href;
        return (
          <li>
            <a
              href={link.href}
              class={`block rounded-full px-5 py-3 text-sm font-semibold uppercase tracking-[0.12em] no-underline transition ${
                isActive
                  ? "bg-gold text-dark"
                  : "text-sand hover:bg-sand/10 hover:text-gold"
              }`}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</header>

<script>
  const nav = document.getElementById("main-nav");
  const inner = document.getElementById("nav-inner");
  const logo = document.getElementById("nav-logo");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      nav.style.top = "6px";
      inner.style.maxWidth = "900px";
      inner.style.padding = "6px 16px";
      logo.style.height = "36px";
    } else {
      nav.style.top = "";
      inner.style.maxWidth = "";
      inner.style.padding = "";
      logo.style.height = "";
    }
  });
</script>