---
const navLinks = [
  { href: "/about", label: "About" },
  { href: "/myths", label: "Myths" },
  { href: "/glossary", label: "Glossary" },
  { href: "/team", label: "Team" },
];

const currentPath = Astro.url.pathname;
---

<header
  id="main-nav"
  class="fixed left-0 top-0 z-50 w-full transition-transform duration-500 md:px-10" >
  <nav class="flex mx-auto max-w-7xl px-6 md:px-10items-center justify-between shadow-[0_18px_35px_-28px_rgba(0,0,0,0.45)] backdrop-blur-md">
    <!-- Logo -->
    <a href="/" class="flex items-center no-underline py-2">
      <img
        src="/logo.svg"
        alt="Éire Lore"
        class="h-12 w-auto object-contain md:h-24"
      />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-10 list-none md:flex">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href;
        return (
          <li class="relative">
            <a
              href={link.href}
              class={`relative inline-block text-sm font-medium uppercase tracking-[0.12em] no-underline transition duration-300 ${
                isActive ? "text-gold" : "text-sand/75 hover:text-gold"
              }`}
            >
              {link.label}


              {isActive && (
  <span class="absolute -bottom-2 left-1/2 h-[2px] w-8 -translate-x-1/2 rounded-full bg-gold"></span>
)}
            </a>
          </li>
        );
      })}


    </ul>

    <!-- Right -->
    <div class="flex items-center gap-3">
      <!-- Search -->

      <div class="relative flex items-center">
  <input
    id="search-input"
    type="text"
    placeholder="Search myths..."
    class="absolute right-14 top-1/2 hidden h-11 w-48 -translate-y-1/2 rounded-full border border-gold/20 bg-dark/90 px-4 text-sm text-sand placeholder:text-sand/45 outline-none backdrop-blur-md focus:border-gold"
  />

  <button
    id="search-btn"
    aria-label="Search"
    type="button"
    class="flex h-11 w-11 items-center justify-center rounded-full border border-gold/25 text-sand transition hover:border-gold hover:text-gold"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="1.5"
      class="h-5 w-5"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M21 21l-4.35-4.35m1.6-5.15a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z"
      />
    </svg>
  </button>
      </div>

      <!-- Mobile menu -->
      <button
        id="menu-btn"
        aria-label="Open menu"
        type="button"
        class="flex h-11 w-11 items-center justify-center rounded-full border border-gold/25 text-sand transition hover:border-gold hover:text-gold md:hidden"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
          class="h-6 w-6"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
          />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="mx-auto mt-4 hidden max-w-7xl rounded-2xl border border-gold/15 bg-dark/95 p-4 backdrop-blur-md md:hidden"
  >
    <ul class="flex flex-col gap-2 list-none">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block rounded-xl px-4 py-3 text-sm font-medium uppercase tracking-[0.08em] text-sand no-underline transition hover:bg-forest/60 hover:text-gold"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const searchBtn = document.getElementById("search-btn");
  const searchInput = document.getElementById("search-input");
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  if (searchBtn && searchInput) {
    searchBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      searchInput.classList.toggle("hidden");
      if (!searchInput.classList.contains("hidden")) searchInput.focus();
    });

    searchInput.addEventListener("click", (e) => e.stopPropagation());
  }

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      mobileMenu.classList.toggle("hidden");
    });

    mobileMenu.addEventListener("click", (e) => e.stopPropagation());
  }

  document.addEventListener("click", () => {
    if (searchInput && !searchInput.classList.contains("hidden")) {
      searchInput.classList.add("hidden");
    }
    if (mobileMenu && !mobileMenu.classList.contains("hidden")) {
      mobileMenu.classList.add("hidden");
    }
  });
</script>

<script>
  const nav = document.getElementById("main-nav");

  let lastScrollY = window.scrollY;
  let isHoveringNav = false;

  if (nav) {
    nav.addEventListener("mouseenter", () => {
      isHoveringNav = true;
      nav.classList.remove("-translate-y-full");
    });

    nav.addEventListener("mouseleave", () => {
      isHoveringNav = false;
    });

    window.addEventListener("scroll", () => {
      const currentScrollY = window.scrollY;

      if (isHoveringNav) return;

      if (currentScrollY > lastScrollY && currentScrollY > 80) {
        nav.classList.add("-translate-y-full");
      } else {
        nav.classList.remove("-translate-y-full");
      }

      lastScrollY = currentScrollY;
    });

    document.addEventListener("mousemove", (e) => {
      if (e.clientY < 90) {
        nav.classList.remove("-translate-y-full");
      }
    });
  }
</script>
