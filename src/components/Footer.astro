---

<footer class="w-full ">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-12 px-10 py-14 md:grid-cols-3">

    <!-- Left -->
    <div>
      <div class="flex items-center gap-4">
        <img
          src="/logo-footer.svg"
          alt="Éire Lore"
          class="h-16 w-auto object-contain"
        />

        <div>
          <p class="text-base font-semibold text-sand">
            Irish Legends Website
          </p>
          <p class="text-xs uppercase tracking-[0.2em] text-gold/80">
            Dissertation Project
          </p>
        </div>
      </div>

      <p class="mt-6 max-w-sm text-sm leading-relaxed text-sand/60">
        A digital space to explore Irish myths through storytelling,
        visual design, cultural context, and interactive reading experiences.
      </p>

      <!-- Find us -->
      <div class="mt-8 flex items-center gap-5">
        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-gold">
          Find us on
        </p>
          <a
            href="#"
            aria-label="Instagram"
            class="text-sand/45 transition hover:text-gold"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="h-6 w-6">
              <path d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9A5.5 5.5 0 0 1 16.5 22h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2Zm9 2h-9A3.5 3.5 0 0 0 4 7.5v9A3.5 3.5 0 0 0 7.5 20h9A3.5 3.5 0 0 0 20 16.5v-9A3.5 3.5 0 0 0 16.5 4Z"/>
              <path d="M12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z"/>
            </svg>
          </a>

          <a
            href="#"
            aria-label="GitHub"
            class="text-sand/45 transition hover:text-gold"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="h-6 w-6">
              <path d="M12 2C6.48 2 2 6.58 2 12.23c0 4.52 2.87 8.35 6.84 9.7.5.1.68-.22.68-.49 0-.24-.01-1.03-.01-1.87-2.78.62-3.37-1.2-3.37-1.2-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.63.07-.63 1 .08 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.67.35-1.11.63-1.37-2.22-.26-4.56-1.15-4.56-5.13 0-1.13.39-2.05 1.03-2.78-.1-.26-.45-1.32.1-2.75 0 0 .84-.28 2.75 1.06A9.3 9.3 0 0 1 12 6.84c.85 0 1.7.12 2.5.35 1.9-1.34 2.74-1.06 2.74-1.06.56 1.43.21 2.49.11 2.75.64.73 1.03 1.65 1.03 2.78 0 3.99-2.34 4.87-4.57 5.13.36.32.68.95.68 1.92 0 1.39-.01 2.5-.01 2.84 0 .27.18.59.69.49A10.03 10.03 0 0 0 22 12.23C22 6.58 17.52 2 12 2Z"/>
            </svg>
          </a>

      </div>
    </div>

    <!-- Middle -->
    <div class="grid grid-cols-2 gap-10">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-gold">
          Explore
        </p>
        <ul class="mt-4 space-y-3 text-sm">
          <li><a href="/" class="text-sand/70 no-underline transition hover:text-gold">Home</a></li>
          <li><a href="/about" class="text-sand/70 no-underline transition hover:text-gold">About</a></li>
          <li><a href="/myths" class="text-sand/70 no-underline transition hover:text-gold">Myths</a></li>
        </ul>
      </div>

      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-gold">
          Sections
        </p>
        <ul class="mt-4 space-y-3 text-sm">
          <li><a href="/glossary" class="text-sand/70 no-underline transition hover:text-gold">Glossary</a></li>
          <li><a href="/team" class="text-sand/70 no-underline transition hover:text-gold">Team</a></li>
          <li><a href="/myths" class="text-sand/70 no-underline transition hover:text-gold">Featured Legends</a></li>
        </ul>
      </div>
    </div>

    <!-- Right -->
    <div class="flex flex-col items-start md:items-end">
      <img
        src="/griffith_logo.png"
        alt="Griffith College"
        class="h-16 w-auto object-contain opacity-90"
      />

      <p class="mt-6 text-xs text-sand/40">
        © 2026  · All rights reserved
      </p>
    </div>
  </div>
</footer>