---
const myths = [
  {
    id: 1,
    title: "The Children of Lir",
    origin: "Mythological Cycle",
    summary: "A tragic tale of four siblings transformed into swans by their jealous stepmother.",
    story: "According to legend, King Lir's second wife, Aoife, became jealous of the king's love for his four children. Using dark magic, she transformed them into swans, condemning them to spend 900 years wandering the cold waters of Ireland until they heard the bells of the new Christian faith, at which point they would regain their human form, only to age rapidly.",
    themes: ["Transformation", "Family", "Tragedy", "Magic"],
    link: "/ChildrenOfLir", // ← Ruta a la nueva página Astro
    image: "/myths/children-of-lir.png",
  },
  {
    id: 2,
    title: "The Giant's Causeway",
    origin: "Irish Folklore",
    summary: "The legendary tale of the Irish giant Fionn mac Cumhaill and his fierce rivalry with a Scottish giant.",
    story: "According to legend, the Irish giant Fionn mac Cumhaill (Finn MacCool) built the Causeway across the North Channel so he could meet and fight the Scottish giant Benandonner. When Fionn realized the Scottish giant was much larger than him, he fled home. His clever wife, Oonagh, disguised Fionn as a baby. When Benandonner saw the massive 'infant', he was terrified by the thought of how huge the father must be and fled back to Scotland, ripping up the causeway behind him.",
    themes: ["Rivalry", "Cleverness", "Giants", "Nature"],
    link: "/GiantsCauseway", // ← Ruta a la nueva página Astro
    image: "/myths/giants-causeway.png",
  },
  {
    id: 3,
    title: "The Banshee",
    origin: "Irish Folklore",
    summary: "A wailing ancestral spirit whose mournful cry serves as an omen of impending death.",
    story: "The Banshee (Bean Sí, meaning 'woman of the fairy mound') is a female spirit in Irish mythology who heralds the death of a family member, usually by shrieking or keening in the dead of night. She is often described as a pale woman or an old hag with long, flowing hair, wearing a grey cloak. Rather than causing death, she acts as a messenger and a protector of ancient Irish families, mourning their loss before it even happens.",
    themes: ["Omens", "Spirits", "Death", "Family"],
    link: "/Banshee", // ← Ruta a la nueva página Astro
    image: "/myths/banshee.png",
  }
];
---

<section class="px-6 pt-40 pb-24 md:px-10">
  <div class="mx-auto max-w-7xl">
    <div class="mb-12 text-center">
      <h2 class="mt-3 text-4xl font-semibold text-sand md:text-5xl">
        Irish Myths & Legends
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-sand/70">
        Discover the ancient stories, heroic sagas, and mystical folklore that shaped our cultural heritage
      </p>
    </div>

    <!-- Grid de tarjetas enlazadas -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {myths.map((myth) => (
        <a
          href={myth.link}
          class="group flex flex-col overflow-hidden rounded-[1.6rem] border border-transparent bg-dark/35 text-left shadow-[0_10px_30px_-18px_rgba(0,0,0,0.45)] transition duration-300 hover:-translate-y-1 hover:border-gold/30"
        >
          <div class="aspect-[4/5] overflow-hidden">
            <img
              src={myth.image}
              alt={myth.title}
              class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
            />
          </div>

          <!-- Contenido de la tarjeta flex-1 asegura que el CTA siempre quede abajo -->
          <div class="flex flex-1 flex-col border-t border-transparent bg-dark/50 p-6 md:p-8">
            <p class="text-xs uppercase tracking-[0.12em] text-gold/85">
              {myth.origin}
            </p>
            
            <h3 class="mt-2 text-2xl font-semibold text-sand">
              {myth.title}
            </h3>
            
            <p class="mt-4 flex-1 text-base leading-relaxed text-sand/80">
              {myth.summary}
            </p>
            
            <!-- Call To Action (CTA) con flecha animada -->
            <div class="mt-8 flex items-center text-sm font-semibold uppercase tracking-wider text-gold transition-colors group-hover:text-gold/80">
              Read full story
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                class="ml-2 h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" 
                fill="none" 
                viewBox="0 0 24 24" 
                stroke="currentColor" 
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>