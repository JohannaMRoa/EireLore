---
const myths = [
  {
    id: 1,
    title: "The Children of Lir",
    origin: "Mythological Cycle",
    summary: "Four siblings, stripped of their royal lives by a cruel curse. A tragic tale of jealousy, dark magic, and an unimaginable fate.",
    themes: ["Transformation", "Family", "Tragedy", "Magic"],
    link: "/ChildrenOfLir", 
    image: "/myths/children-of-lir.jpeg",
  },
  {
    id: 2,
    title: "The Giant's Causeway",
    origin: "Irish Folklore",
    summary: "An epic rivalry across the sea. A true story of bravery, cunning, and the colossal clash that forged the Causeway.",
    link: "/GiantsCauseway", 
    image: "/myths/giants-causeway.png",
  },
  {
    id: 3,
    title: "The Banshee",
    origin: "Irish Folklore",
    summary: "The most feared sound in Irish folklore. Uncover the truth behind the sorrowful spirit whose midnight cry foretells an inescapable fate.",
    themes: ["Omens", "Spirits", "Death", "Family"],
    link: "/Banshee", 
    image: "/myths/banshee.jpeg",
  }
];
---

<section class="px-6 pt-40 pb-24 md:px-10">
  <div class="mx-auto max-w-4xl">


    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {myths.map((myth) => (
        <a
          href={myth.link}
          class="group flex flex-col overflow-hidden rounded-[1.6rem] border border-transparent bg-dark/35 text-left shadow-[0_10px_30px_-18px_rgba(0,0,0,0.45)] transition duration-300 hover:-translate-y-1 hover:border-gold/30"
        >
          <div class="aspect-[4/5] overflow-hidden">
            <img
              src={myth.image}
              alt={myth.title}
              class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
            />
          </div>


          <div class="flex flex-1 flex-col border-t border-transparent bg-dark/50 p-6 md:p-8">
            <p class="text-xs uppercase tracking-[0.12em] text-gold/85">
              {myth.origin}
            </p>
            
            <h3 class="mt-2 text-2xl font-semibold text-sand">
              {myth.title}
            </h3>
            
            <p class="mt-4 flex-1 text-base leading-relaxed text-sand/80">
              {myth.summary}
            </p>
            
            <div class="mt-8 flex items-center text-sm font-semibold uppercase tracking-wider text-gold transition-colors group-hover:text-gold/80">
              Full story
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                class="ml-2 h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" 
                fill="none" 
                viewBox="0 0 24 24" 
                stroke="currentColor" 
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>