---
const team = [
  {
    id: 1,
    name: "Johanna Montiel",
    role: "UI / UX & Visual Concept Designer",
    bio: "Focused on the interface design, visual concept, and user experience of the project, creating cohesive layouts, interactive sections, and a strong visual identity that supports the storytelling of Irish legends.",
    skills: ["UI design", "Visual concept", "Interface systems"],
    contact: "nadiajohanna.montielroa@student.griffith.ie",
    image: "/team/member-1.png",
  },
  {
    id: 2,
    name: "Fabiana Banegas",
    role: "UX Researcher & Content Lead",
    bio: "focused on the project's structural planning, helping research the Irish myths, design the site map, and guide the overall user experience.",
    skills: ["Project planning", "Content strategy", "Information architecture"],
    contact: "laurafabiana.banegasrivero@student.griffith.ie",
    image: "/team/member-2.png",
  },
  {
    id: 3,
    name: "Sumeyye Yilmaz",
    role: "Lead Designer & UI Specialist",
    bio: "led the visual direction of the project, designing the logo, establishing the overall brand identity, and creating the user interface and visual assets.",
    skills: ["Brand identity", "UI design", "Graphic design"],
    contact: "teammate3@email.com",
    image: "/team/member-3.png",
  },
  {
    id: 4,
    name: "Denilson Madeira",
    role: "Product Designer & Technical Lead",
    bio: "led the development of the physical side of the project. He was responsible for designing and modelling the 3D characters, preparing them for resin printing, and managing the full production process including post-processing and painting. He also worked on integrating NFC technology into the objects and contributed to the technical structure and documentation of the project",
    skills: ["3D Artist and 3D printing", " Product design", "Creative direction"],
    contact: "denilson.americosantosmadeira@student.griffith.ie",
    image: "/team/member-4.png",
  },
];
---

<section class="px-6 pt-40 pb-24 md:px-10">
  <div class="mx-auto max-w-7xl">
    <div class="mb-12 text-center">
      <h2 class="mt-3 text-4xl font-semibold text-sand md:text-5xl">
        Meet the Creators
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-sand/70">
        The team working to preserve and share Irish cultural heritage through interactive design
    </div>

    <!-- Static cards -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {team.map((member, index) => (
        <button
          type="button"
          class={`team-card group overflow-hidden rounded-[1.6rem] border border-transparent bg-dark/35 text-left shadow-[0_10px_30px_-18px_rgba(0,0,0,0.45)] transition duration-300 hover:-translate-y-1 hover:border-gold/30 ${index === 0 ? "is-active" : ""}`}
          data-member={JSON.stringify(member)}
        >
          <div class="aspect-[4/5] overflow-hidden">
            <img
              src={member.image}
              alt={member.name}
              class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
            />
          </div>

          <div class="border-t border-transparen bg-dark/50 p-4">
            <h3 class="text-lg font-semibold text-sand">{member.name}</h3>
            <p class="mt-1 text-xs uppercase tracking-[0.12em] text-gold/85">
              {member.role}
            </p>
          </div>
        </button>
      ))}
    </div>

    <!-- Expandable detail panel -->
    <div
      id="team-detail"
      class="team-detail-open mt-8 overflow-hidden rounded-[2rem] border border-transparent bg-dark/35 shadow-[0_20px_50px_-30px_rgba(0,0,0,0.55)] backdrop-blur-sm transition-all duration-500"
    >
      <div class="grid md:grid-cols-[280px_1fr]">
        <div class="min-h-[320px] bg-forest/25">
          <img
            id="detail-image"
            src={team[0].image}
            alt={team[0].name}
            class="h-full w-full object-cover"
          />
        </div>

        <div class="p-8 md:p-10">
          <p id="detail-role" class="text-sm uppercase tracking-[0.18em] text-gold">
            {team[0].role}
          </p>

          <h3 id="detail-name" class="mt-3 text-3xl font-semibold text-sand md:text-4xl">
            {team[0].name}
          </h3>

          <p id="detail-short" class="mt-4 text-lg leading-relaxed text-sand/80">
            {team[0].short}
          </p>

          <p id="detail-bio" class="mt-6 max-w-3xl leading-relaxed text-sand/68">
            {team[0].bio}
          </p>

          <div class="mt-8">
            <p class="text-sm uppercase tracking-[0.14em] text-gold">Skills</p>
            <div id="detail-skills" class="mt-4 flex flex-wrap gap-3">
              {team[0].skills.map((skill) => (
                <span class="rounded-full border border-gold/15 bg-forest/25 px-4 py-2 text-sm text-sand/85">
                  {skill}
                </span>
              ))}
            </div>
          </div>

          <div class="mt-8">
            <p class="text-sm uppercase tracking-[0.14em] text-gold">Contact</p>
            <a
              id="detail-contact"
              href={`mailto:${team[0].contact}`}
              class="mt-3 inline-block text-sand/80 underline decoration-gold/50 underline-offset-4 transition hover:text-gold"
            >
              {team[0].contact}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="../scripts/team-showcase.js"></script>