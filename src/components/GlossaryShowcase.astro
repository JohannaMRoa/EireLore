---
// Aquí agregas las nuevas palabras. El código las ordenará automáticamente.
const glossaryData = [
  {
    term: "Aoife",
    pronunciation: "EE-fa",
    meaning: "A mythical princess and the second wife of King Lir. Consumed by jealousy, she used dark magic to transform her stepchildren into swans.",
    related_story: "The Children of Lir",
    link: "/ChildrenOfLir"
  },
  {
    term: "Banshee",
    pronunciation: "BAN-shee",
    meaning: "A female spirit from Irish mythology whose mournful wail is believed to be an omen of impending death for an ancient family.",
    related_story: "The Banshee",
    link: "/Banshee"
  },
  {
    term: "Bradán Feasa",
    pronunciation: "BRA-dawn FA-sa",
    meaning: "The Salmon of Knowledge, a magical fish that contained all the wisdom of the world. Whoever ate it first would gain its absolute knowledge.",
    related_story: "The Salmon of Knowledge",
    link: "#"
  },
  {
    term: "Cú Chulainn",
    pronunciation: "koo CULL-in",
    meaning: "An Irish mythological demigod and hero of the Ulster Cycle, renowned for his terrifying battle frenzy (ríastrad).",
    related_story: "The Ulster Cycle",
    link: "#"
  },
  {
    term: "Fionn mac Cumhaill",
    pronunciation: "FIN mac COOL",
    meaning: "A mythical hunter-warrior and leader of the Fianna. He is said to have built the Giant's Causeway to fight a Scottish giant.",
    related_story: "The Giant's Causeway",
    link: "/GiantsCauseway"
  },
  {
    term: "Tír na nÓg",
    pronunciation: "TEER na NOG",
    meaning: "The Land of Eternal Youth in Irish mythology, an otherworldly realm where illness and death do not exist.",
    related_story: "Oisín in Tír na nÓg",
    link: "#"
  }
];

// Lógica automática para ordenar y agrupar (No necesitas modificar esto)
glossaryData.sort((a, b) => a.term.localeCompare(b.term));

const groupedGlossary = glossaryData.reduce((acc, item) => {
  const letter = item.term.charAt(0).toUpperCase();
  if (!acc[letter]) {
    acc[letter] = [];
  }
  acc[letter].push(item);
  return acc;
}, {} as Record<string, typeof glossaryData>);

const alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("");
---

<section class="px-6 pt-40 pb-24 md:px-10">
  <div class="mx-auto max-w-7xl">
    
    <div class="mb-12 border-b border-gold/20 pb-8 text-center md:text-left">
      <h2 class="text-4xl font-semibold text-sand md:text-5xl">Irish Glossary</h2>
      <p class="mt-4 max-w-2xl text-lg text-sand/70">
        A guide to the magic and myths of ancient Ireland
      </p>
    </div>

    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[280px_1fr]">

      <aside>
        <div class="mb-4 flex items-center justify-between border-b border-gold/10 pb-2">
          <h2 class="text-lg font-medium text-sand">Filters</h2>
        </div>

        <div class="mt-6">
          <div class="mb-3 flex items-center justify-between">
            <h3 class="text-sm font-semibold uppercase tracking-widest text-gold/80">Alphabetical</h3>
            <button id="clear-filter" class="hidden text-xs text-sand/60 transition hover:text-gold">Clear</button>
          </div>
          
          <div class="flex flex-wrap gap-2">
            <button class="letter-btn is-active flex h-9 w-9 items-center justify-center rounded bg-gold/20 text-sm font-semibold text-sand transition hover:bg-gold/30" data-letter="ALL">
              All
            </button>
            {alphabet.map((letter) => (
              <button
                class="letter-btn flex h-9 w-9 items-center justify-center rounded border border-transparent bg-dark/40 text-sm font-medium text-sand/60 transition hover:border-gold/30 hover:text-sand"
                data-letter={letter}
              >
                {letter}
              </button>
            ))}
          </div>
        </div>
      </aside>


      <main>
        <div class="mb-8 flex flex-col-reverse justify-between gap-4 border-b border-gold/10 pb-4 sm:flex-row sm:items-end">
          <p class="text-sand/80">
            Results: <span id="results-count" class="text-lg font-bold text-sand">{glossaryData.length}</span>
          </p>
          
          <div class="relative w-full sm:w-72">
            <input
              type="text"
              id="search-input"
              placeholder="Search glossary..."
              class="w-full rounded border border-gold/20 bg-dark/50 px-4 py-2 text-sand placeholder-sand/40 focus:border-gold/60 focus:outline-none focus:ring-1 focus:ring-gold/60"
            />
            <svg class="absolute right-3 top-2.5 h-5 w-5 text-sand/40" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
        </div>

        <div id="glossary-list" class="space-y-12">
          {Object.keys(groupedGlossary).map((letter) => (
            <div class="letter-group" data-letter={letter}>
              <h2 class="mb-6 text-4xl font-bold text-gold">{letter}.</h2>
              
              <div class="space-y-8 pl-2 md:pl-4">
                {groupedGlossary[letter].map((item) => (
                  <div class="term-item group grid grid-cols-1 gap-1 md:grid-cols-[1fr_2fr]">
                    <div class="pr-4">
                      <h3 class="text-xl font-bold text-sand">{item.term}</h3>
                      <p class="mt-1 font-mono text-sm tracking-wide text-sand/50">/{item.pronunciation}/</p>
                    </div>
                    
                    <div>
                      <p class="leading-relaxed text-sand/80">{item.meaning}</p>
                      {item.related_story && (
                        <div class="mt-3 flex items-center gap-2 text-sm font-medium">
                          <span class="text-gold/70">Related Story:</span>
                          <a href={item.link} class="text-sand underline decoration-gold/40 underline-offset-4 transition hover:text-gold">
                            {item.related_story}
                          </a>
                        </div>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
        
        <div id="no-results" class="hidden py-12 text-center text-sand/60">
          No terms found matching your search criteria.
        </div>
      </main>
    </div>
  </div>
</section>

<script src="../scripts/glossary-showcase.js"></script>