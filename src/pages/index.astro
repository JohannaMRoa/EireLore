---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Irish Legends Website">
  <section class="relative min-h-screen px-6 pt-40 pb-20 md:px-10">
    
    <img
      src="/assets/candle-1.gif"
      alt=""
      class="fixed inset-0 -z-20 h-full w-full object-cover"
    />

    <div class="absolute inset-0 -z-10 bg-black/45"></div>

    <div class="mx-auto flex max-w-7xl flex-col justify-center">
      <p class="text-sm uppercase tracking-[0.2em] text-gold">
        Irish Legends
      </p>

      <h1 class="mt-6 text-6xl font-bold leading-tight text-sand md:text-8xl">
        Enter the world of Irish myths
      </h1>

      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-sand/70">
        Discover heroes, creatures, and ancient stories through immersive
        scrollytelling.
      </p>
    </div>
  </section>
</Layout>