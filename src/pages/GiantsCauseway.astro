---
import LegendLayout from "../layouts/LegendLayout.astro";
---

<LegendLayout title="The Giant's Causeway">

  <!----------------------- SCENE 1: THE COAST AND THE TWO GIANTS ----------------------->

  <section class="giant-pan-section scene-1 relative h-[500vh]">
    <div class="sticky top-0 h-screen overflow-hidden">

      <!-- Background panorama -->
      <img
        id="giant-panorama"
        src="/Giants caseway/Giant_scene.png"
        alt="The Giant's Causeway panoramic story scene"
        class="absolute top-0 left-0 h-full max-w-none"
      />

      <!-- Dark overlay -->
      <div class="absolute inset-0 bg-gradient-to-t from-dark/75 via-dark/20 to-transparent"></div>

      <!-- Story text -->
      <div class="absolute left-8 top-1/2 z-20 max-w-4xl -translate-y-1/2 md:left-16">
        <p class="legend-line text-3xl leading-tight text-sand md:text-5xl">
          On the wild north coast of Ireland lived
        </p>
        <p class="legend-line text-3xl leading-tight text-sand md:text-5xl">
          Fionn Mac Cumhaill
        </p>

        <p class="legend-line text-3xl leading-tight text-sand md:text-5xl">
          He was strong, proud, and known across the land for his courage
        </p>

        <p class="legend-line text-3xl leading-tight text-sand md:text-5xl">
          Across the sea in Scotland
        </p>

        <p class="legend-line text-3xl leading-tight text-sand md:text-5xl">
          lived another giant, 
        </p>
        <p class="legend-line text-3xl leading-tight text-sand md:text-5xl">
          Benandonner
        </p>

        <p class="legend-line text-3xl leading-tight text-sand md:text-5xl">
        He boasted loudly and challenged 
        Fionn again and again
        </p>

        <img
        class="bubble_speak"
        src="/Giants caseway/bubble_text1.png"
        class="absolute top-0 left-0 h-full max-w-none"
      />
       <img
        class="bubble_speak"
        src="/Giants caseway/bubble_text2.png"
        class="absolute top-0 left-0 h-full max-w-none"
      />

      </div>
    </div>
  </section>

  <!----------------------- SCENE 2: STONES / ACTION ----------------------->
  <!-- Later we add the next image and the text:
  Fionn began tearing stones from the earth.
  One by one, he hurled them into the sea.
  -->

</LegendLayout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initSceneOne = () => {
    const image = document.getElementById("giant-panorama");
    const section = document.querySelector(".giant-pan-section");
    const legendLines = document.querySelectorAll(".legend-line");

    if (!image || !section || !legendLines.length) return;

    const animateScene = () => {
      ScrollTrigger.getAll().forEach((trigger) => trigger.kill());
      gsap.killTweensOf(image);

      const imageWidth = image.offsetWidth;
      const viewportWidth = window.innerWidth;
      const overflow = imageWidth - viewportWidth;

      if (overflow <= 0) return;

      // Image pan: starts on the right side, moves towards the left side
      gsap.fromTo(
        image,
        { x: -overflow },
        {
          x: 0,
          ease: "none",
          scrollTrigger: {
            trigger: section,
            start: "top top",
            end: "bottom bottom",
            scrub: 1,
            invalidateOnRefresh: true,
          },
        }
      );

      // Text animation
      gsap.set(legendLines, {
        opacity: 0,
        y: 30,
        scale: 0.96,
      });

      const textTimeline = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "top top",
          end: "bottom bottom",
          scrub: 1,
        },
      });

      legendLines.forEach((line, index) => {
        textTimeline.to(line, {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 1,
        });

        if (index !== legendLines.length - 1) {
          textTimeline.to(line, {
            opacity: 0,
            y: -30,
            scale: 1.02,
            duration: 1,
          });
        }
      });
    };

    if (image.complete) {
      animateScene();
    } else {
      image.addEventListener("load", animateScene);
    }

    window.addEventListener("resize", animateScene);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initSceneOne);
  } else {
    initSceneOne();
  }
</script>