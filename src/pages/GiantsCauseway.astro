---
import LegendLayout from "../layouts/LegendLayout.astro";

---

<LegendLayout title="The Giant's Causeway">
  <section class="giant-pan-section relative h-[500vh]">
    <div class="sticky top-0 h-screen overflow-hidden">
      <img
        id="giant-panorama"
        src="/Giants caseway/giant3.png"
        alt="The Giant's Causeway panoramic story scene"
        class="absolute top-0 left-0 h-full max-w-none"
      />

      <div class="story-text absolute bottom-16 left-6 z-20 max-w-3xl md:left-10">
  <div class="legend-title">
    <p class="text-sm uppercase tracking-[0.18em] text-gold">
      Irish Myth
    </p>

    <h1 class="mt-4 font-[var(--font-title)] text-6xl leading-none text-sand md:text-8xl">
      The Giant&apos;s Causeway
    </h1>
  </div>

  <div class="legend-lines mt-8">
    <p class="legend-line text-3xl leading-tight text-sand md:text-5xl">
      On the wild north coast of Ireland lived Fionn mac Cumhaill.
    </p>

    <p class="legend-line text-3xl leading-tight text-sand md:text-5xl">
      A giant known for his strength, pride, and courage.
    </p>

    <p class="legend-line text-3xl leading-tight text-sand md:text-5xl">
      Across the sea waited another giant — Benandonner.
    </p>

    <p class="legend-line text-3xl leading-tight text-sand md:text-5xl">
      Fionn began tearing stones from the earth.
    </p>

    <p class="legend-line text-3xl leading-tight text-sand md:text-5xl">
      One by one, he hurled them into the sea.
    </p>
  </div>
</div>
    </div>
  </section>
</LegendLayout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initGiantPan = () => {
    const image = document.getElementById("giant-panorama");
    const section = document.querySelector(".giant-pan-section");

    if (!image || !section) return;

    const animatePan = () => {
      ScrollTrigger.getAll().forEach((trigger) => trigger.kill());
      gsap.killTweensOf(image);

      const legendTitle = document.querySelector(".legend-title");
const legendLines = document.querySelectorAll(".legend-line");

gsap.set(legendLines, {
  opacity: 0,
  y: 30,
  scale: 0.96,
});

gsap.timeline({
  scrollTrigger: {
    trigger: section,
    start: "top top",
    end: "bottom bottom",
    scrub: 1,
  },
})
  .fromTo(
    legendTitle,
    { opacity: 1, y: 0 },
    { opacity: 0, y: -40, duration: 1.2 }
  )
  .to(legendLines[0], { opacity: 1, y: 0, scale: 1, duration: 1 })
  .to(legendLines[0], { opacity: 0, y: -30, scale: 1.02, duration: 1 })
  .to(legendLines[1], { opacity: 1, y: 0, scale: 1, duration: 1 })
  .to(legendLines[1], { opacity: 0, y: -30, scale: 1.02, duration: 1 })
  .to(legendLines[2], { opacity: 1, y: 0, scale: 1, duration: 1 })
  .to(legendLines[2], { opacity: 0, y: -30, scale: 1.02, duration: 1 })
  .to(legendLines[3], { opacity: 1, y: 0, scale: 1, duration: 1 })
  .to(legendLines[3], { opacity: 0, y: -30, scale: 1.02, duration: 1 })
  .to(legendLines[4], { opacity: 1, y: 0, scale: 1, duration: 1 });

      const imageWidth = image.offsetWidth;
      const viewportWidth = window.innerWidth;
      const overflow = imageWidth - viewportWidth;

      if (overflow <= 0) return;

      gsap.fromTo(
        image,
        {
          x: -overflow, // empieza mostrando la derecha
        },
        {
          x: 0, // termina mostrando la izquierda completa
          ease: "none",
          scrollTrigger: {
            trigger: section,
            start: "top top",
            end: "bottom bottom",
            scrub: 1,
            invalidateOnRefresh: true,
          },
        }
      );
    };

    if (image.complete) {
      animatePan();
    } else {
      image.addEventListener("load", animatePan);
    }

    window.addEventListener("resize", animatePan);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initGiantPan);
  } else {
    initGiantPan();
  }
</script>