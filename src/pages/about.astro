---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About">
  <section class="relative overflow-hidden px-6 pt-40 pb-20 md:px-10">
    <img
      src="/assets/candle-2.gif"
      alt=""
      class="fixed inset-0 -z-20 h-full w-full object-cover"
    />

    <div class="fixed inset-0 -z-10 bg-black/50"></div>

    <div class="mx-auto max-w-7xl">
      <div class="story-block mb-32 text-center">

        <h1 class="mt-6 text-center">
          <span class="block text-5xl font-semibold leading-tight text-sand md:text-7xl">
            The Story Behind
          </span>

          <div class="relative mx-auto mt-6 w-fit">
            <div class="absolute inset-0 rounded-full bg-gold/10 blur-2xl"></div>

            <img
              src="/logo.svg"
              alt="Éire Lore"
              class="relative h-20 w-auto md:h-62"
            />
          </div>
        </h1>

        <p class="text-box mx-auto mt-6 max-w-2xl text-base leading-relaxed text-sand/72 md:text-lg">
          Discover the ideas, goals, and cultural motivations behind a digital
          heritage project that reimagines Irish legends through interactive storytelling.
        </p>

        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <span class="text-box rounded-full border border-white/10 bg-dark/20 px-4 py-2 text-sm text-sand/75">
            Digital Heritage
          </span>
          <span class="text-box rounded-full border border-white/10 bg-dark/20 px-4 py-2 text-sm text-sand/75">
            Irish Mythology
          </span>
          <span class="text-box rounded-full border border-white/10 bg-dark/20 px-4 py-2 text-sm text-sand/75">
            Scrollytelling
          </span>
        </div>
      </div>

      <section class="story-block min-h-screen flex items-center py-28">
        <div class="text-box mx-auto max-w-4xl text-center rounded-[2rem] border border-white/8 bg-dark/25 p-8 backdrop-blur-sm">
          <p class="mx-auto max-w-2xl leading-relaxed text-sand/75 md:text-lg">
            Éire Lore is an interactive digital heritage project that brings Irish
            legends to life through 3D-printed figures and QR-based storytelling.
            Each collectible object connects users to immersive legend pages with
            narration, visuals, and animated story moments.
          </p>
        </div>
      </section>

      <section class="story-block py-28 min-h-screen">
        <div class="mx-auto max-w-7xl">
          <div class="text-box mx-auto max-w-3xl text-center">
            <h2 class="mt-3 text-4xl font-semibold text-sand md:text-5xl">
              Goals
            </h2>
            <p class="mt-6 text-base leading-relaxed text-sand/75 md:text-lg">
              The project aims to make Irish mythology more engaging, accessible, and
              memorable through digital storytelling, visual design, and immersive interaction.
            </p>
          </div>

          <div class="mt-20 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            <button type="button" class="text-box rounded-[1.6rem] border border-white/8 bg-dark/25 p-6 text-left transition duration-300 hover:-translate-y-1">
              <p class="text-sm uppercase tracking-[0.14em] text-gold/75">01</p>
              <h3 class="mt-4 text-2xl font-semibold text-sand">Preserve Folklore</h3>
            </button>

            <button type="button" class="text-box rounded-[1.6rem] border border-white/8 bg-dark/25 p-6 text-left transition duration-300 hover:-translate-y-1">
              <p class="text-sm uppercase tracking-[0.14em] text-gold/75">02</p>
              <h3 class="mt-4 text-2xl font-semibold text-sand">Engage Through Design</h3>
            </button>

            <button type="button" class="text-box rounded-[1.6rem] border border-white/8 bg-dark/25 p-6 text-left transition duration-300 hover:-translate-y-1">
              <p class="text-sm uppercase tracking-[0.14em] text-gold/75">03</p>
              <h3 class="mt-4 text-2xl font-semibold text-sand">Improve Accessibility</h3>
            </button>

            <button type="button" class="text-box rounded-[1.6rem] border border-white/8 bg-dark/25 p-6 text-left transition duration-300 hover:-translate-y-1">
              <p class="text-sm uppercase tracking-[0.14em] text-gold/75">04</p>
              <h3 class="mt-4 text-2xl font-semibold text-sand">Create Interaction</h3>
            </button>
          </div>
        </div>
      </section>

      <section class="story-block py-32 min-h-screen flex items-center">
        <div class="mx-auto grid max-w-7xl items-center gap-14 lg:grid-cols-[1.1fr_0.9fr]">
          <div class="text-box">
            <h2 class="mt-4 text-5xl font-semibold leading-none text-sand md:text-7xl">
              Purpose
            </h2>

            <p class="mt-8 max-w-2xl text-lg leading-relaxed text-sand/75">
              Éire Lore reconnects modern audiences with Irish mythology through
              accessible, portable, and emotionally engaging digital storytelling.
              By combining physical artefacts with responsive web experiences, the
              project bridges heritage and contemporary interaction.
            </p>
          </div>

          <div class="grid gap-5">
            <div class="text-box rounded-[1.6rem] border border-white/8 bg-dark/25 p-6 backdrop-blur-sm">
              <h3 class="text-lg font-semibold text-sand">Accessible</h3>
              <p class="mt-2 text-sm leading-relaxed text-sand/68">
                The experience is web-based and QR-driven, making it easy to access
                without a dedicated app or complex setup.
              </p>
            </div>

            <div class="text-box rounded-[1.6rem] border border-white/8 bg-dark/25 p-6 backdrop-blur-sm">
              <h3 class="text-lg font-semibold text-sand">Portable</h3>
              <p class="mt-2 text-sm leading-relaxed text-sand/68">
                The project is designed to move beyond museums, allowing myths to
                exist in everyday spaces through physical figures and digital access.
              </p>
            </div>

            <div class="text-box rounded-[1.6rem] border border-white/8 bg-dark/25 p-6 backdrop-blur-sm">
              <h3 class="text-lg font-semibold text-sand">Immersive</h3>
              <p class="mt-2 text-sm leading-relaxed text-sand/68">
                The interface uses narration, visuals, and interaction to transform
                mythology into a more memorable and emotionally resonant experience.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="story-block min-h-screen flex items-center py-32">
        <div class="w-full max-w-7xl">
          <div class="text-box mx-auto max-w-3xl text-center">
            <h2 class="mt-3 text-4xl font-semibold text-sand md:text-5xl">
              Culture & Nostalgia
            </h2>
            <p class="mt-6 leading-relaxed text-sand/75">
              Many people first encounter Irish legends during childhood, but rarely
              revisit them later in life. This project reintroduces those stories
              through nostalgia, cultural identity, and digital immersion, allowing
              users to rediscover familiar myths in a new emotional and interactive way.
            </p>
          </div>

          <div class="mt-20 grid gap-10 md:grid-cols-3">
            <div class="text-box text-center">
              <div class="mx-auto flex h-44 w-44 items-center justify-center rounded-full border border-white/10 bg-dark/30">
                <span class="text-gold text-lg font-semibold">Identity</span>
              </div>
              <h3 class="mt-6 text-2xl font-semibold text-sand">Identity</h3>
              <p class="mx-auto mt-3 max-w-xs text-sm leading-relaxed text-sand/68">
                Irish myths reflect a shared cultural identity, connecting landscape,
                history, and imagination across generations.
              </p>
            </div>

            <div class="text-box text-center">
              <div class="mx-auto flex h-44 w-44 items-center justify-center rounded-full border border-white/10 bg-dark/30">
                <span class="text-gold text-lg font-semibold">Memory</span>
              </div>
              <h3 class="mt-6 text-2xl font-semibold text-sand">Memory</h3>
              <p class="mx-auto mt-3 max-w-xs text-sm leading-relaxed text-sand/68">
                For many users, these stories carry nostalgic value, bringing back
                early memories of school, storytelling, and childhood discovery.
              </p>
            </div>

            <div class="text-box text-center">
              <div class="mx-auto flex h-44 w-44 items-center justify-center rounded-full border border-white/10 bg-dark/30">
                <span class="text-gold text-lg font-semibold">Rediscovery</span>
              </div>
              <h3 class="mt-6 text-2xl font-semibold text-sand">Rediscovery</h3>
              <p class="mx-auto mt-3 max-w-xs text-sm leading-relaxed text-sand/68">
                Digital interaction offers a new way to reconnect with familiar
                legends, making them feel contemporary, accessible, and alive again.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="story-block min-h-screen flex items-center py-32">
        <div class="text-box max-w-3xl rounded-[2rem] border border-white/8 bg-dark/25 p-8 backdrop-blur-sm">
          <h2 class="mt-3 text-4xl font-semibold text-sand md:text-5xl">
            Why it Matters
          </h2>
          <p class="mt-6 leading-relaxed text-sand/75">
            Éire Lore demonstrates how digital media can preserve intangible cultural
            heritage in ways that feel intuitive for contemporary audiences. It
            transforms passive reading into active discovery, showing how design,
            storytelling, and interaction can strengthen cultural memory.
          </p>
        </div>
      </section>
    </div>
  </section>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const boxes = document.querySelectorAll(".text-box");

  boxes.forEach((box, index) => {
    gsap.fromTo(
      box,
      {
        opacity: 0,
        y: 80,
        scale: 0.92,
        filter: "blur(8px)",
      },
      {
        opacity: 1,
        y: 0,
        scale: 1,
        filter: "blur(0px)",
        duration: 1,
        delay: (index % 4) * 0.12,
        ease: "power3.out",
        scrollTrigger: {
          trigger: box,
          start: "top 60%",
          toggleActions: "play none none reverse",
        },
      }
    );
  });
</script>