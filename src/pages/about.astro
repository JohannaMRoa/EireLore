---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About">
  <section class="relative overflow-hidden px-6 pt-40 pb-20 md:px-10">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_center,rgba(216,169,27,0.10),transparent_32%),radial-gradient(circle_at_20%_30%,rgba(255,255,255,0.03),transparent_20%)]"></div>

    <div class="mx-auto max-w-7xl">
      <div class="mb-20 text-center">
        <p class="text-sm uppercase tracking-[0.2em] text-gold/80">
          About the Dissertation
        </p>

        <h1 class="mt-6 text-center">
          <span class="block text-5xl font-semibold leading-tight text-sand md:text-7xl">
            The Story Behind
          </span>

          <div class="relative mx-auto mt-6 w-fit">
            <div class="absolute inset-0 rounded-full bg-gold/10 blur-2xl"></div>

            <img
              src="/logo.svg"
              alt="Éire Lore"
              class="relative h-20 w-auto md:h-32"
            />
          </div>
        </h1>

        <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-sand/72 md:text-lg">
          Discover the ideas, goals, and cultural motivations behind a digital
          heritage project that reimagines Irish legends through interactive storytelling.
        </p>

        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <span class="rounded-full border border-white/10 bg-dark/20 px-4 py-2 text-sm text-sand/75">
            Digital Heritage
          </span>
          <span class="rounded-full border border-white/10 bg-dark/20 px-4 py-2 text-sm text-sand/75">
            Irish Mythology
          </span>
          <span class="rounded-full border border-white/10 bg-dark/20 px-4 py-2 text-sm text-sand/75">
            Scrollytelling
          </span>
        </div>

        <div class="mt-12 flex justify-center">
          <div class="h-px w-40 bg-gradient-to-r from-transparent via-gold/70 to-transparent"></div>
        </div>
      </div>

      <!----------------------- Project Description ---------------------------------------->

      <div class="space-y-16">
        <section class="story-block py-20">
          <div class="max-w-3xl">

            <h2 class="mt-4 text-4xl font-semibold text-sand md:text-5xl">
              Project Description
            </h2>

            <p class="mt-6 max-w-2xl leading-relaxed text-sand/75">
              Éire Lore is an interactive digital heritage project that brings Irish
              legends to life through 3D-printed figures and QR-based storytelling.
              Each collectible object connects users to immersive legend pages with
              narration, visuals, and animated story moments.
            </p>
          </div>
        </section>



<!----------------------- Goals ---------------------------------------->

        <section class="story-block px-6 py-24 md:px-10">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mt-3 text-4xl font-semibold text-sand md:text-5xl">
        Goals
      </h2>
      <p class="mt-6 text-base leading-relaxed text-sand/75 md:text-lg">
        The project aims to make Irish mythology more engaging, accessible, and
        memorable through digital storytelling, visual design, and immersive
        interaction.
      </p>
    </div>

    <div class="mt-16 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div class="text-center">
        <div class="mx-auto flex h-40 w-40 items-center justify-center overflow-hidden rounded-full border border-white/10 bg-dark/30 shadow-[0_14px_30px_-18px_rgba(0,0,0,0.45)]">
          <img
            src="/goals/goal-1.png"
            alt="Preserve Irish myths"
            class="h-full w-full object-cover"
          />
        </div>
        <h3 class="mt-6 text-xl font-semibold text-sand">
          Preserve Folklore
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-sand/68">
          Present Irish myths in a digital format that helps preserve cultural
          memory and storytelling traditions.
        </p>
      </div>

      <div class="text-center">
        <div class="mx-auto flex h-40 w-40 items-center justify-center overflow-hidden rounded-full border border-white/10 bg-dark/30 shadow-[0_14px_30px_-18px_rgba(0,0,0,0.45)]">
          <img
            src="/goals/goal-2.png"
            alt="Engage users visually"
            class="h-full w-full object-cover"
          />
        </div>
        <h3 class="mt-6 text-xl font-semibold text-sand">
          Engage Through Design
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-sand/68">
          Use visuals, layout, and interaction to create a more immersive and
          emotionally engaging reading experience.
        </p>
      </div>

      <div class="text-center">
        <div class="mx-auto flex h-40 w-40 items-center justify-center overflow-hidden rounded-full border border-white/10 bg-dark/30 shadow-[0_14px_30px_-18px_rgba(0,0,0,0.45)]">
          <img
            src="/goals/goal-3.png"
            alt="Make myths accessible"
            class="h-full w-full object-cover"
          />
        </div>
        <h3 class="mt-6 text-xl font-semibold text-sand">
          Improve Accessibility
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-sand/68">
          Make the stories easier to understand for wider audiences, including
          people less familiar with Irish mythology.
        </p>
      </div>

      <div class="text-center">
        <div class="mx-auto flex h-40 w-40 items-center justify-center overflow-hidden rounded-full border border-white/10 bg-dark/30 shadow-[0_14px_30px_-18px_rgba(0,0,0,0.45)]">
          <img
            src="/goals/goal-4.png"
            alt="Create interactive storytelling"
            class="h-full w-full object-cover"
          />
        </div>
        <h3 class="mt-6 text-xl font-semibold text-sand">
          Create Interaction
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-sand/68">
          Explore scrollytelling as a way to transform traditional narratives
          into interactive digital experiences.
        </p>
      </div>
    </div>
  </div>
</section>





<!----------------------- Purpose ---------------------------------------->



       <section class="story-block relative py-28">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_20%_30%,rgba(216,169,27,0.08),transparent_30%),radial-gradient(circle_at_80%_70%,rgba(255,255,255,0.04),transparent_25%)]"></div>

  <div class="mx-auto grid max-w-7xl items-center gap-14 lg:grid-cols-[1.1fr_0.9fr]">
    <div>
      <h2 class="mt-4 text-5xl font-semibold leading-none text-sand md:text-7xl">
        Purpose
      </h2>

      <p class="mt-8 max-w-2xl text-lg leading-relaxed text-sand/75">
        Éire Lore reconnects modern audiences with Irish mythology through
        accessible, portable, and emotionally engaging digital storytelling.
        By combining physical artefacts with responsive web experiences, the
        project bridges heritage and contemporary interaction.
      </p>
    </div>

    <div class="grid gap-4">
      <div class="rounded-[1.6rem] border border-white/8 bg-dark/25 p-6 backdrop-blur-sm shadow-[0_16px_40px_-25px_rgba(0,0,0,0.45)]">
        <h3 class="text-lg font-semibold text-sand">Accessible</h3>
        <p class="mt-2 text-sm leading-relaxed text-sand/68">
          The experience is web-based and QR-driven, making it easy to access
          without a dedicated app or complex setup.
        </p>
      </div>

      <div class="rounded-[1.6rem] border border-white/8 bg-dark/25 p-6 backdrop-blur-sm shadow-[0_16px_40px_-25px_rgba(0,0,0,0.45)]">
        <h3 class="text-lg font-semibold text-sand">Portable</h3>
        <p class="mt-2 text-sm leading-relaxed text-sand/68">
          The project is designed to move beyond museums, allowing myths to
          exist in everyday spaces through physical figures and digital access.
        </p>
      </div>

      <div class="rounded-[1.6rem] border border-white/8 bg-dark/25 p-6 backdrop-blur-sm shadow-[0_16px_40px_-25px_rgba(0,0,0,0.45)]">
        <h3 class="text-lg font-semibold text-sand">Immersive</h3>
        <p class="mt-2 text-sm leading-relaxed text-sand/68">
          The interface uses narration, visuals, and interaction to transform
          mythology into a more memorable and emotionally resonant experience.
        </p>
      </div>
    </div>
  </div>
</section>



<!----------------------- Culture and Nostalgia ---------------------------------------->



        <section class="story-block min-h-screen flex items-center">
  <div class="w-full max-w-7xl">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mt-3 text-4xl font-semibold text-sand md:text-5xl">
        Culture & Nostalgia
      </h2>
      <p class="mt-6 leading-relaxed text-sand/75">
        Many people first encounter Irish legends during childhood, but rarely
        revisit them later in life. This project reintroduces those stories
        through nostalgia, cultural identity, and digital immersion, allowing
        users to rediscover familiar myths in a new emotional and interactive way.
      </p>
    </div>

    <div class="culture-circles mt-16 grid gap-10 md:grid-cols-3">
      <div class="culture-item text-center">
        <div class="mx-auto flex h-44 w-44 items-center justify-center rounded-full border border-white/10 bg-dark/30 shadow-[0_14px_30px_-18px_rgba(0,0,0,0.45)]">
          <span class="text-gold text-lg font-semibold">Identity</span>
        </div>
        <h3 class="mt-6 text-2xl font-semibold text-sand">
          Identity
        </h3>
        <p class="mx-auto mt-3 max-w-xs text-sm leading-relaxed text-sand/68">
          Irish myths reflect a shared cultural identity, connecting landscape,
          history, and imagination across generations.
        </p>
      </div>

      <div class="culture-item text-center">
        <div class="mx-auto flex h-44 w-44 items-center justify-center rounded-full border border-white/10 bg-dark/30 shadow-[0_14px_30px_-18px_rgba(0,0,0,0.45)]">
          <span class="text-gold text-lg font-semibold">Memory</span>
        </div>
        <h3 class="mt-6 text-2xl font-semibold text-sand">
          Memory
        </h3>
        <p class="mx-auto mt-3 max-w-xs text-sm leading-relaxed text-sand/68">
          For many users, these stories carry nostalgic value, bringing back
          early memories of school, storytelling, and childhood discovery.
        </p>
      </div>

      <div class="culture-item text-center">
        <div class="mx-auto flex h-44 w-44 items-center justify-center rounded-full border border-white/10 bg-dark/30 shadow-[0_14px_30px_-18px_rgba(0,0,0,0.45)]">
          <span class="text-gold text-lg font-semibold">Rediscovery</span>
        </div>
        <h3 class="mt-6 text-2xl font-semibold text-sand">
          Rediscovery
        </h3>
        <p class="mx-auto mt-3 max-w-xs text-sm leading-relaxed text-sand/68">
          Digital interaction offers a new way to reconnect with familiar
          legends, making them feel contemporary, accessible, and alive again.
        </p>
      </div>
    </div>
  </div>
</section>




<!----------------------- Why it matters ---------------------------------------->



              <section class="story-block min-h-screen flex items-center">
        <div class="max-w-3xl">
          <h2 class="mt-3 text-4xl font-semibold text-sand md:text-5xl">
            Why it Matters
          </h2>
          <p class="mt-6 leading-relaxed text-sand/75">
            Éire Lore demonstrates how digital media can preserve intangible cultural
            heritage in ways that feel intuitive for contemporary audiences. It
            transforms passive reading into active discovery, showing how design,
            storytelling, and interaction can strengthen cultural memory.
          </p>
        </div>
      </section>

      </div>
    </div>
  </section>
</Layout>


<!----------------------- JAVASCRIPT ---------------------------------------->


<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initAboutScroll = () => {
    const sections = document.querySelectorAll(".story-block");

    sections.forEach((section) => {
      gsap.fromTo(
        section,
        {
          opacity: 0,
          y: 80,
        },
        {
          opacity: 1,
          y: 0,
          duration: 0.9,
          ease: "power2.out",
          scrollTrigger: {
            trigger: section,
            start: "top 78%",
            end: "top 30%",
            toggleActions: "play reverse play reverse",
          },
        }
      );
    });

    const cultureItems = document.querySelectorAll(".culture-item");

    if (cultureItems.length) {
      gsap.fromTo(
        cultureItems,
        {
          opacity: 0,
          y: 40,
          scale: 0.92,
        },
        {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 0.7,
          ease: "power2.out",
          stagger: 0.18,
          scrollTrigger: {
            trigger: ".culture-circles",
            start: "top 80%",
            end: "bottom 30%",
            toggleActions: "play reverse play reverse",
          },
        }
      );
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAboutScroll);
  } else {
    initAboutScroll();
  }
</script>